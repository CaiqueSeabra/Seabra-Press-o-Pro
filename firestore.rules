rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/measurements
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - The ID of the user
    //   - period: string (required) - 'morning', 'afternoon', 'night'
    //   - systolic: number (required) - Systolic pressure
    //   - diastolic: number (required) - Diastolic pressure
    //   - pulse: number (required) - Heart rate
    //   - timestamp: timestamp (required) - When the measurement was taken
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] > 0;
    }

    function isValidPeriod() {
      return request.resource.data.period in ['morning', 'afternoon', 'night'];
    }

    function isRecent(time) {
      // Relaxed check to ensure serverTimestamp() is always valid
      // and allow some buffer for client-side timestamps if needed.
      return time > request.time - duration.value(24, 'h') &&
             time <= request.time + duration.value(1, 'm');
    }

    function isValidMeasurement(userId) {
      return hasOnlyAllowedFields(['userId', 'period', 'systolic', 'diastolic', 'pulse', 'timestamp']) &&
             hasRequiredFields(['userId', 'period', 'systolic', 'diastolic', 'timestamp']) &&
             request.resource.data.userId == userId &&
             isValidPeriod() &&
             isPositive('systolic') && request.resource.data.systolic < 300 &&
             isPositive('diastolic') && request.resource.data.diastolic < 200 &&
             (!('pulse' in request.resource.data) || (isPositive('pulse') && request.resource.data.pulse < 250)) &&
             request.resource.data.timestamp is timestamp &&
             isRecent(request.resource.data.timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId}/measurements/{measurementId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMeasurement(userId);
      allow update: if isOwner(userId) && isValidMeasurement(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }
  }
}
